##### Note: These aliases are shared with zsh aliases #####
# Note: -G means "colorize" on BSD/macOS but "no group names" on GNU/Linux.
# On Linux, use --color=auto for colored output instead.
alias ll='ls -alFG'
alias la='ls -AG'
alias l='ls -CFG'
# your web root directory
alias webroot="cd /var/www/html"
# your web config directory
alias siteconfig="cd /etc/nginx/sites-available"
alias kubectl='microk8s kubectl'
